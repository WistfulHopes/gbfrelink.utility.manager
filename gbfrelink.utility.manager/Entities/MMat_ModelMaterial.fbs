enum ShadowType : byte
{
	NoShadow = 0,
	ShadowEnable_Unk1 = 1,
	ShadowEnable_AlphaBlend = 2,
	ShadowEnable_NoAlphaBlend = 3,
}

struct ShaderParamInfo // Fetched at ref: 56 57 48 83 EC ? 48 89 D6 48 89 CF 41 0F B6 C0
{
    param_hash:ShaderParameterTypeNameHash;
    value_or_offset:ushort; // When float/Vec2/3/4 this is an offset to the float pool
    value_type:ShaderParamValueType;
}

table GraniteVirtualTextureStreamingInfo
{
    page_file:[string];
    layer_to_shader_map_name_hash:[ShaderMapTypeHash];
    unk4:byte; // No idea. Never more than 4.
    unk5:byte; // No idea. Never more than 5.
    tile_set_number:byte; // 0 to 11 max
}

table TextureMapInfo
{
    shader_map_name_hash:ShaderMapTypeHash;
    texture_name:string;
}

table Material
{
    shader_params:[ShaderParamInfo];
    texture_maps:[TextureMapInfo];
    constant_buffer_indices:[ushort];
    granite_params:GraniteVirtualTextureStreamingInfo;
    unique_material_name_hash_maybe:uint;
    shader_type:byte;
    shader_sub_type:byte;
    shadow_type:ShadowType; // 0-3
    bool9:bool;
    bool10:bool;
    ignore_alpha:bool;
    bool12:bool;
} 

table ConstantBuffer
{
    buffer:[uint];
    unk_unique_param_name_hash:uint;
}

table ModelMaterialSet (fs_serializer) {
    magic:uint;
    materials:[Material];
    constant_buffers:[ConstantBuffer];
    shader_param_float_data_pool:[float];
    unk2:byte; // Not all .mmat sets this one, but 'em' mat files seems to do so
    bool3:bool;
    bool4:bool; // Rare
    bool5:bool; // Rare
}

file_extension "mmat";
root_type ModelMaterialSet;