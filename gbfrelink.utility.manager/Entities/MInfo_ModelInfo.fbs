include "BaseStructs.fbs";

// all FlatSharp FBS attributes start with the 'fs_' prefix.
attribute "fs_serializer";

namespace GBFRDataTools.FlatBuffers;

enum VertexBufferType:ubyte (bit_flags) 
{
    POS_NOR_TAN_UV0 = 0, // 0x0F, 0x00, 0x20
    BLENDINDICES    = 1, // 0x0C, 0x00, 0x08
    BLENDINDICES_2  = 2, // 0x0C, 0x01, 0x08
    BLENDWEIGHT     = 3, // 0x0B, 0x00, 0x08
    BLENDWEIGHT_2   = 4, // 0x0B, 0x01, 0x08
    COLOR           = 5, // 0x05, 0x00, 0x04
    TEXCOORD        = 6, // 0x08, 0x01, 0x04
}

// Structure hierarchy:
//   asset::impl::ModelBundleImpl (loader for all core model files)
//   - asset:impl::ModelImpl
//     - asset::impl::ModelInfoImpl <- THIS FILE (holds minfo buffer)
//       - ModelImpl::MeshImpl
//     - asset::impl::SkeletonImpl (holds skeleton)
//     - asset::impl::MaterialSet_Mmat (holds mmat)
//     - wind::Receiver_Point
//     - model::scene_graph::SendModelToSGComponentImpl
table ModelInfo (fs_serializer) 
{
    magic:uint; // 20230729 (1.0.0), 20240213 (>=1.1.1)
    lods:[StreamLOD];
    shadow_lods:[StreamLOD];
    lod_screen_size_thresholds:[float]; // Only read once (stage load)
    meshes:[MeshInfo]; // Names of meshes. This is directly used by the engine (hardcoded names) to toggle on/off certain meshes.
    materials:[MaterialInfo]; // refer to lods->chunks->material_id instead. This one's purpose is unknown.
    deform_bone_to_bone_index_table:[ushort];
    deform_bone_boundary_box:[BoundaryBox];
    bounding_sphere:Vec4;
    bg_reaction_data:BgReactionData; // Only supported by bg objects. Interaction data (when walking through). Only read once (stage load)
    vec3_11:Vec3; // Unknown. Only read once (stage load)
    near_camera_bound_radius:float; // Unknown. Seems to range from values between 1 (on average) to 500 (bg6866, seedhollow pillar?)
    near_camera_detection_scale:float; // Unknown. Seems to range from 0 to 5
    fade_out_distance:float; // Distance at which the object starts fading out for the camera. Only read once (stage load)
    f15:float; // Used very rarely in bg objects, mainly grass ground objects (which themselves don't even seem used except bg020f). Couldn't get it to be read.
    f16:float; // Unknown. couldn't get to be read.
    f17:float; // Unknown. couldn't get to be read.
    f18:float; // Unknown. couldn't get to be read.
    f19:float; // Unknown. couldn't get to be read.
    u20:uint; // Unknown, couldn't get to be read. Appears to be some sort of color.
    byte21:byte; // Unknown. Only read once (stage load) - changed to many values with no visible changes (pl0000)
    scene_graph_mode:byte;      // (0-3) - Read on load & every tick. Unknown.
    use_scene_graph_cache:bool; // Whether to cache LOD/draw calls? Used for all bg & tr objects. If true: model::scene_graph::SendModelToSGComponentCacheImpl, otherwise model::scene_graph::SendModelToSGComponentImpl
    bool24:bool; // Unknown, read on every tick. Used for some bg objects.
    is_ship:bool; // Unknown. Only used for ba0001 and ba2106 (grandcypher & avia ships?)
    bool26:bool; // Unknown. Couldn't get to be read.
    use_bone_bounds_for_fade: bool; // Only read once (stage load). Animation related? Seems to do stuff when starting to sprint
    bool28:bool; // Unknown. Couldn't get to be read.
    bool29:bool; // Unknown. Couldn't get to be read, used by all ba0426, em2600, pl2100 (sandalphon) & most wp objects
    force_near_fade_evaluation:bool; // Unknown. Used by ba0402, ba0426 and most wp objects.
    bool31:byte; // Unused?
    use_mesh_aabb_for_fade:bool; // Couldn't get to be read.
    // 1.1.1
    render_flags:byte; // bit1/2/3 - Flags? Anim related? Seems related to bool27 anyhow. Only read once (stage load)
    camera_near_fade_aabb_radius:float; // Unknown. Couldn't get to be read.
}

table StreamLOD
{
    buffers:[BufferLocator];
    chunks:[LODChunk];
    vertex_count:int;
    index_count:int;
    buffer_types:VertexBufferType;
    a6:ubyte;
}

// ModelImpl::MeshImpl
table MeshInfo
{
    name:string;
    bbox:BoundaryBox;
}

table MaterialInfo
{
    unique_name_hash:uint;
    material_flags:byte;
}

enum BgReactionParticleType : byte
{
    None = 0,
    Leaves = 1,
    Sand = 2,
    Unk3 = 3,
}

// This is read only once on map load.
table BgReactionData
{
    hit_height:float;
    hit_radius:float;
    particle_type:BgReactionParticleType;
    play_sound:bool;
}

/////////////////
// Util structs
/////////////////
struct BufferLocator
{
    offset:ulong;
    size:ulong;
}

struct LODChunk
{
    offset:int;
    count:int;
    mesh_id:byte; // Index into MeshInfo.
    material_id:byte; // Index into MMat's Materials.
    a5:byte;
    a6:byte;
}

file_extension "minfo";
root_type ModelInfo;